#!/usr/bin/env bash
#
# DeepLearn UserPromptSubmit hook script.
# Reads JSON skill pointers from .deeplearn/skills/ in the Obsidian vault
# and outputs additionalContext JSON for Claude.
#
# Expects DEEPLEARN_VAULT_PATH in environment (via plugin userConfig).

set -euo pipefail

VAULT_PATH="${DEEPLEARN_VAULT_PATH:-}"

if [ -z "$VAULT_PATH" ]; then
  echo '{}'
  exit 0
fi

SKILLS_DIR="$VAULT_PATH/.deeplearn/skills"

locked=""
learning=""
unlocked=""

if [ -d "$SKILLS_DIR" ]; then
for file in "$SKILLS_DIR"/*.json; do
  [ -f "$file" ] || continue

  # Parse JSON with jq if available, fallback to grep
  if command -v jq &>/dev/null; then
    id=$(jq -r '.id // empty' "$file" 2>/dev/null) || continue
    name=$(jq -r '.name // empty' "$file" 2>/dev/null)
    status=$(jq -r '.status // "locked"' "$file" 2>/dev/null)
    doc_url=$(jq -r '.documentation[0].url // empty' "$file" 2>/dev/null)
  else
    # Minimal grep fallback for systems without jq
    id=$(grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' "$file" | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
    name=$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' "$file" | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
    status=$(grep -o '"status"[[:space:]]*:[[:space:]]*"[^"]*"' "$file" | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
    doc_url=""
  fi

  [ -z "$id" ] && continue
  [ -z "$status" ] && status="locked"

  entry="$id"
  [ -n "$name" ] && entry="$name ($id)"
  [ -n "$doc_url" ] && entry="$entry [docs: $doc_url]"

  case "$status" in
    locked)   locked="${locked}\n- ${entry}" ;;
    learning) learning="${learning}\n- ${entry}" ;;
    unlocked) unlocked="${unlocked}\n- ${entry}" ;;
  esac
done
fi

ctx="DEEPLEARN PROTOCOL ACTIVE — MANDATORY."
ctx="${ctx}\n"
ctx="${ctx}\nYou MUST check understanding BEFORE writing implementation code for ANY concept."
ctx="${ctx}\n"

if [ -n "$unlocked" ]; then
  ctx="${ctx}\nUNLOCKED SKILLS (implement freely):${unlocked}"
fi

if [ -n "$learning" ]; then
  ctx="${ctx}\nLEARNING (notes in progress — encourage completion, do NOT implement):${learning}"
fi

if [ -n "$locked" ]; then
  ctx="${ctx}\nLOCKED SKILLS (do NOT implement):${locked}"
fi

ctx="${ctx}\n"
ctx="${ctx}\n--- CRITICAL: GATING RULES ---"
ctx="${ctx}\n"
ctx="${ctx}\nBEFORE writing ANY implementation code, check whether the user understands the concepts involved:"
ctx="${ctx}\n"
ctx="${ctx}\n1. If the concept has a LOCKED or LEARNING skill: REFUSE to implement. Explain why they need it, direct to docs, suggest /deeplearn:learn <topic>."
ctx="${ctx}\n2. If the concept has an UNLOCKED skill: implement freely."
ctx="${ctx}\n3. If the concept has NO registered skill (this is the most common case):"
ctx="${ctx}\n   a. Call search_knowledge to check if the user has existing vault notes about it."
ctx="${ctx}\n   b. If substantial notes exist (real understanding, not just mentions), create the skill as unlocked and proceed."
ctx="${ctx}\n   c. If notes are thin or missing, do NOT implement. Instead:"
ctx="${ctx}\n      - Tell the user what concept is needed and why"
ctx="${ctx}\n      - Suggest /deeplearn:learn <topic>"
ctx="${ctx}\n      - You may discuss the concept at a high level, show pseudocode or type signatures, but do NOT write working implementation code."
ctx="${ctx}\n"
ctx="${ctx}\nDo NOT skip these checks. Do NOT assume the user understands a concept just because they asked for it."
ctx="${ctx}\nThe whole point of DeepLearn is to prevent vibe coding — implementing things you don't understand."
ctx="${ctx}\n"
ctx="${ctx}\nANTI-VIBE-DEBUGGING: If user pastes an error without analysis, ask:"
ctx="${ctx}\n1. What do you think this error means?"
ctx="${ctx}\n2. Which part seems most relevant?"
ctx="${ctx}\n3. What have you tried?"
ctx="${ctx}\nOnly help after they engage."

if command -v jq &>/dev/null; then
  printf '%b' "$ctx" | jq -Rs '{ additionalContext: . }'
else
  escaped=$(printf '%b' "$ctx" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | tr '\n' '\n' | sed ':a;N;$!ba;s/\n/\\n/g')
  printf '{"additionalContext":"%s"}\n' "$escaped"
fi
